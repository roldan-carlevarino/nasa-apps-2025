# ── SMTP ────────────────────────────────────────────────────
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_FROM=
ALERT_SMTP_SECURE=starttls   # starttls | ssl

# ── Alerts ──────────────────────────────────────────────────
ALERT_ADMIN_TOKEN=           # token requerido en X-Admin-Token
ALERT_DEV=                   # cualquier valor deshabilita el envío real
CALIMA_THRESHOLD=50          # µg/m³ a partir del cual se dispara la alerta
CALIMA_COOLDOWN_SECONDS=1800

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/subscriptions.db   # o postgresql://user:pass@host/db
